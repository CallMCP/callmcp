{
  "name": "callmcp-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "CallMCP — one MCP tool contract for telephony, any call provider. Monorepo root.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "dev": "pnpm --filter @callmcp/server run dev",
    "lint": "pnpm -r --filter=./packages/* run lint",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck",
    "test": "pnpm -r --filter=./packages/* run test",
    "conformance": "pnpm --filter @callmcp/driver-interface run conformance",
    "clean": "pnpm -r --filter=./packages/* run clean"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
